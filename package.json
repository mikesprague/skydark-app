{
  "name": "skydark-app",
  "version": "4.0.0-rc.6",
  "private": true,
  "description": "Open source PWA built as an homage to the now defunct Dark Sky for Android app",
  "keywords": [],
  "homepage": "https://skydark.app",
  "license": "MIT",
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "repository": {
    "url": "https://github.com/mikesprague/skydark-app"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf ./build",
    "dev": "vite serve",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=development concurrently 'npm run build -- --watch' 'npm run wrangler-pages-dev'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "wrangler-pages-dev": "wrangler pages dev --live-reload true --local true ./build"
  },
  "dependencies": {
    "@bugsnag/core": "8.9.0",
    "@bugsnag/js": "8.9.0",
    "@bugsnag/plugin-react": "8.9.0",
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "@fortawesome/free-brands-svg-icons": "7.3.0",
    "@fortawesome/free-regular-svg-icons": "7.3.0",
    "@fortawesome/free-solid-svg-icons": "7.3.0",
    "@fortawesome/pro-duotone-svg-icons": "7.3.0",
    "@fortawesome/pro-light-svg-icons": "7.3.0",
    "@fortawesome/pro-regular-svg-icons": "7.3.0",
    "@fortawesome/pro-solid-svg-icons": "7.3.0",
    "@fortawesome/pro-thin-svg-icons": "7.3.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@tippyjs/react": "4.2.6",
    "cross-env": "10.1.0",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "jose": "6.2.3",
    "leaflet": "1.9.4",
    "nanoid": "5.1.16",
    "prop-types": "15.8.1",
    "query-string": "9.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-geolocated": "4.5.1",
    "react-google-charts": "5.2.1",
    "react-leaflet": "5.0.0",
    "sweetalert2": "11.26.25",
    "sweetalert2-react-content": "5.1.2",
    "tippy.js": "6.3.7",
    "use-local-storage-state": "19.5.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "8.0.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "concurrently": "10.0.3",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.2",
    "vite": "8.1.1",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0",
    "wrangler": "4.105.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "volta": {
    "node": "26.4.0",
    "npm": "11.18.0"
  },
  "packageManager": "npm@11.18.0",
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true,
    "workerd@1.20260625.1": true
  }
}
